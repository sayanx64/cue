{
  "name": "cue",
  "version": "0.1.0",
  "description": "Open-source Windows/macOS AI overlay — screen, mic, and meeting audio into an LLM. A Cluely-style copilot for meetings and coding problems.",
  "license": "GPL-3.0-or-later",
  "author": "cue",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "dist:win": "electron-builder --win nsis portable",
    "dist:mac": "electron-builder --mac zip"
  },
  "build": {
    "appId": "com.cue.overlay",
    "productName": "cue",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "cue transcribes your microphone so it can help you in conversations.",
        "NSCameraUsageDescription": "cue does not use the camera.",
        "NSAudioCaptureUsageDescription": "cue captures system audio to transcribe the other participant in a call."
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-installer-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-portable-${arch}.${ext}"
    }
  },
  "keywords": [
    "electron",
    "overlay",
    "ai",
    "assistant",
    "windows",
    "macos"
  ],
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^0.3.0",
    "lucide-static": "^0.468.0",
    "openai": "^4.73.0"
  }
}
